{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.0",
        "barryvdh/laravel-snappy": "^1.0",
        "doctrine/dbal": "^3.3",
        "freshbitsweb/laravel-log-enhancer": "^1.5",
        "giggsey/libphonenumber-for-php": "^9.0",
        "google/cloud-firestore": "^1.37",
        "guzzlehttp/guzzle": "^7.2",
        "inertiajs/inertia-laravel": "^0.6.3",
        "jorenvanhocht/laravel-share": "^4.2",
        "kreait/laravel-firebase": "^5.7",
        "laravel/framework": "^10.48.0",
        "laravel/horizon": "^5.15",
        "laravel/pulse": "^1.0@beta",
        "laravel/sanctum": "^3.2",
        "laravel/slack-notification-channel": "^3.0",
        "laravel/tinker": "^2.8",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-ftp": "^3.29",
        "maatwebsite/excel": "^3.1",
        "mews/captcha": "^3.2",
        "nnjeim/world": "^1.1",
        "opcodesio/log-viewer": "^3.0",
        "opencage/geocode": "^3.3",
        "phpoffice/phpspreadsheet": "^1.23",
        "picqer/php-barcode-generator": "^2.2",
        "pragmarx/google2fa-laravel": "^2.2",
        "pragmarx/recovery": "^0.2.1",
        "psr/simple-cache": "^1.0",
        "retail-cosmos/ioi-city-mall-sales-file": "^1.0",
        "retail-cosmos/trx-mall-upload-sales-data-api": "^1.0",
        "sentry/sentry-laravel": "4.8.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-data": "^3.5",
        "spatie/laravel-directory-cleanup": "^1.9",
        "spatie/laravel-health": "^1.23",
        "spatie/laravel-medialibrary": "^11.8",
        "spatie/laravel-permission": "6.0",
        "spatie/laravel-url-signer": "^3.2",
        "tightenco/ziggy": "2.3.0",
        "webklex/laravel-pdfmerger": "^1.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.8",
        "driftingly/rector-laravel": "^1.2",
        "fakerphp/faker": "^1.9.1",
        "larastan/larastan": "^2.9",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "peckphp/peck": "^0.1.3",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "spatie/laravel-horizon-watcher": "^1.1",
        "spatie/laravel-ignition": "^2.0",
        "symplify/easy-coding-standard": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "bash make_dir.sh",
            "@php artisan app:generate-google-service-json-file"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "code-refactoring": "php artisan optimize:clear && truncate -s 0 file-changed-list.txt && git diff --diff-filter=ACMRTUXB --name-only main >> file-changed-list.txt && rector process --clear-cache && ecs --fix --clear-cache && npm run eslint-fix && GREEN='\\033[0;32m' && printf \"${GREEN}Congrats! All good. You can push now.\n\"",
        "code-analysis-test": "php artisan optimize:clear && phpstan analyze && pest --parallel && GREEN='\\033[0;32m' && printf \"${GREEN}Congrats! All good. You can push now.\n\"",
        "code-quality": "php artisan optimize:clear && truncate -s 0 file-changed-list.txt && git diff --diff-filter=ACMRTUXB --name-only main >> file-changed-list.txt && rector process --clear-cache && ecs --fix --clear-cache && npm run eslint-fix && peck && phpstan analyze && pest --parallel && GREEN='\\033[0;32m' && printf \"${GREEN}Congrats! All good. You can push now.\n\"",
        "generate-changed-files": "truncate -s 0 file-changed-list.txt && git diff --diff-filter=ACMRTUXB --name-only main >> file-changed-list.txt",
        "rector": "php artisan optimize:clear && truncate -s 0 file-changed-list.txt && git diff --diff-filter=ACMRTUXB --name-only main >> file-changed-list.txt && rector process --clear-cache",
        "phpstan": "php artisan optimize:clear && phpstan analyze",
        "peck": "peck"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "package_comments": {
            "spatie/laravel-activitylog": "Used for logging activities on models and user actions",
            "spatie/laravel-medialibrary": "Used for media management",
            "spatie/laravel-permission": "Used for role-based permissions",
            "spatie/laravel-url-signer": "Used for generating signed URLs",
            "spatie/laravel-health": "Used for monitoring the health of the application",
            "spatie/laravel-data": "Used for data handling and manipulation",
            "spatie/laravel-directory-cleanup": "Used for cleaning up temporary files",
            "spatie/laravel-horizon-watcher": "Used for watching Horizon",
            "spatie/laravel-ignition": "Used for debugging exceptions",
            "barryvdh/laravel-dompdf": "Used for generate the pdf from the html"
        }
    },
    "config": {
        "process-timeout": 600,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
